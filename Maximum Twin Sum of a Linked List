# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def pairSum(self, head: Optional[ListNode]) -> int:
        max_twin=float('-inf')
        # temp=self.head
        slow=head
        fast=head
        while fast and fast.next:
            slow=slow.next
            fast=fast.next.next
        second=slow
        prev=None
        curr=slow
        # next_node=curr.next
        while curr:
            next_node=curr.next
            curr.next=prev
            prev=curr
            curr=next_node
        second=prev
        first=head
        while second and first:
            twin_sum=first.val+second.val
            max_twin=max(max_twin,twin_sum)
            first=first.next
            second=second.next
        return max_twin
