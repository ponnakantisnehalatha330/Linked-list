# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def oddEvenList(self, head: Optional[ListNode]) -> Optional[ListNode]:
        odd_start=ListNode(0)
        odd_end=odd_start
        even_start=ListNode(0)
        even_end=even_start
        temp=head
        while temp:
            odd_end.next=temp
            odd_end=temp
            temp=temp.next
            if temp:
                even_end.next=temp
                even_end=temp
                temp=temp.next
        odd_end.next=even_start.next
        even_end.next=None
        head=odd_start.next
        return head
