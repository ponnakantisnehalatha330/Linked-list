class Node:
    def __init__(self,data):
        self.data=data
        self.next=None
class single:
    def __init__(self):
        self.head=None
    def even_odd(self):
        if self.head is None:
            print("empty list")
        else:
            odd=[]
            even=[]
            temp=self.head
            while temp:
                if temp.data%2==0:
                    even.append(temp.data)
                    
                else:
                    odd.append(temp.data)
                temp=temp.next
            res=even+odd
            for i in range(len(res)-1):
                print(res[i],end="->")
            print(res[-1])
         
